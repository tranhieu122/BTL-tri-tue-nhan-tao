        <mxCell id="s20" value="⑲ Backend gửi kết quả về Frontend&lt;br&gt;(gồm: đường đi tìm được, chi phí,&lt;br&gt;danh sách từng bước duyệt, thời gian)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1">
