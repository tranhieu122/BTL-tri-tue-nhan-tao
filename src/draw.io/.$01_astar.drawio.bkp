          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e7" value="RỒI (bỏ qua)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;fontColor=#C62828;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="a6" target="a4">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="510" y="835" />
              <mxPoint x="510" y="555" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e8" value="CHƯA" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;fontColor=#2E7D32;fontStyle=1;" edge="1" parent="1" source="a6" target="a7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="a7" target="a8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e10" value="ĐÚNG RỒI! 🎉" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=11;fontColor=#2E7D32;fontStyle=1;strokeWidth=2;strokeColor=#2E7D32;" edge="1" parent="1" source="a8" target="a8_yes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e11" value="CHƯA PHẢI (tiếp tục tìm)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;fontColor=#E65100;fontStyle=1;" edge="1" parent="1" source="a8" target="a9">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="a9" target="a10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e13" value="ĐÚNG (bỏ qua m)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;fontColor=#C62828;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="a10">
          <mxGeometry relative="1" as="geometry">
