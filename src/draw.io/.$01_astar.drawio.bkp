        <mxCell id="e4" value="TRỐNG (hết tỉnh để xét)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontStyle=1;fontSize=10;fontColor=#C62828;" edge="1" parent="1" source="a4" target="a4_fail">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e5" value="CÒN (vẫn có tỉnh chờ xét)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;fontColor=#2E7D32;fontStyle=1;" edge="1" parent="1" source="a4" target="a5">
          <mxGeometry relative="1" as="geometry" />
