          <mxGeometry x="580" y="600" width="230" height="55" as="geometry" />
        </mxCell>

        <mxCell id="s12" value="⑪ Chọn THUẬT TOÁN&lt;br&gt;(A*, Dijkstra, BFS, DFS,&lt;br&gt;Greedy, UCS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="700" width="210" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s13" value="⑫ Bấm nút &quot;TÌM ĐƯỜNG&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="705" width="230" height="50" as="geometry" />
