        <mxCell id="formula_explain" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;fontColor=#37474F;" value="&lt;b&gt;f(n)&lt;/b&gt; = Tổng chi phí ước tính&lt;br&gt;(dùng để xếp hạng, node nào xét trước)&lt;br&gt;&lt;br&gt;&lt;b&gt;g(n)&lt;/b&gt; = Chi phí THỰC TẾ đã đi&lt;br&gt;(tổng km từ điểm xuất phát đến n)&lt;br&gt;&lt;br&gt;&lt;b&gt;h(n)&lt;/b&gt; = Chi phí ƯỚC LƯỢNG còn lại&lt;br&gt;(khoảng cách đường chim bay từ n&lt;br&gt;đến đích, tính bằng công thức Haversine)" vertex="1">
