        <mxCell id="formula_title" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=14;fontStyle=1;fontColor=#1565C0;" value="💡 CÔNG THỨC CỐT LÕI CỦA A*" vertex="1">
          <mxGeometry height="28" width="260" x="995" y="97" as="geometry" />
        </mxCell>
        <mxCell id="formula_main" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=20;fontStyle=1;fontColor=#C62828;" value="f(n) = g(n) + h(n)" vertex="1">
          <mxGeometry height="35" width="220" x="1015" y="128" as="geometry" />
        </mxCell>
        <mxCell id="formula_detail" parent="1" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;fontSize=11;fontColor=#37474F;" value="&lt;b&gt;f(n)&lt;/b&gt; = Tổng chi phí ước tính&lt;br&gt;(dùng để xếp hạng, node nào xét trước)&lt;br&gt;&lt;br&gt;&lt;b&gt;g(n)&lt;/b&gt; = Chi phí THỰC TẾ đã đi&lt;br&gt;(tổng km từ điểm xuất phát đến n)&lt;br&gt;&lt;br&gt;&lt;b&gt;h(n)&lt;/b&gt; = Chi phí ƯỚC LƯỢNG còn lại&lt;br&gt;(khoảng cách chim bay từ n đến đích,&lt;br&gt;tính bằng công thức Haversine × 0.6)" vertex="1">
          <mxGeometry height="140" width="280" x="985" y="165" as="geometry" />
        </mxCell>

