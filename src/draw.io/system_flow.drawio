        <mxCell id="s1" value="① Chạy lệnh: python app.py&lt;br&gt;(Khởi động Flask Server)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=12;fontStyle=1;" vertex="1" parent="1">
