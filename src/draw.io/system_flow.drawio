        <mxCell id="s2" value="② Server nạp dữ liệu 34 tỉnh thành&lt;br&gt;từ file vietnam_cities.json&lt;br&gt;vào bộ nhớ (NetworkX Graph)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1">
