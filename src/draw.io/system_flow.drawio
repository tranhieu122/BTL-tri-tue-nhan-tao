        <mxCell id="s9" value="⑧ Chọn điểm XUẤT PHÁT&lt;br&gt;(click vào tỉnh trên bản đồ)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;fontStyle=1;" vertex="1" parent="1">
