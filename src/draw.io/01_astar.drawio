        <mxCell id="a8_yes" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontStyle=1;fontSize=11;" value="&lt;br&gt;Trả về thông tin" vertex="1">
