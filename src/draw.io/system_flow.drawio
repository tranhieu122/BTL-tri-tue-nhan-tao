        <mxCell id="s5" value="④ Người dùng mở trình duyệt&lt;br&gt;truy cập localhost:5000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=12;fontStyle=1;" vertex="1" parent="1">
