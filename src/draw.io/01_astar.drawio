        <mxCell id="a10" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;" value="⑨ Với mỗi tỉnh kề m:&lt;br&gt;m đã duyệt rồi&lt;br&gt;HOẶC đường n→m&lt;br&gt;bị chặn?" vertex="1">
          <mxGeometry height="100" width="190" x="260" y="1350" as="geometry" />
        </mxCell>
        <mxCell id="a10_note" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;fontStyle=2;fontColor=#757575;" value="(Nếu đúng: bỏ qua m,&lt;br&gt;xét tỉnh kề tiếp theo)" vertex="1">
          <mxGeometry height="40" width="150" x="500" y="1375" as="geometry" />
        </mxCell>
        <mxCell id="phase5" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;fontStyle=5;fontColor=#C62828;" value="TÍNH TOÁN CHI PHÍ" vertex="1">
          <mxGeometry height="25" width="150" x="40" y="1490" as="geometry" />
        </mxCell>
        <mxCell id="a11" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;fontSize=11;" value="⑩ Tính chi phí mới để đến m qua n:&lt;br&gt;&lt;br&gt;&lt;b&gt;g_mới(m)&lt;/b&gt; = g(n) + khoảng cách(n → m)&lt;br&gt;&lt;br&gt;Ví dụ: nếu đã đi 200km đến n,&lt;br&gt;và n cách m là 50km → g_mới = 250km" vertex="1">
          <mxGeometry height="100" width="340" x="185" y="1520" as="geometry" />
        </mxCell>
        <mxCell id="a12" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;" value="⑪ Đường mới này&lt;br&gt;có TỐT HƠN đường&lt;br&gt;cũ đến m không?&lt;br&gt;&lt;br&gt;(g_mới &lt; g_cũ&lt;br&gt;hoặc m chưa từng xét)" vertex="1">
          <mxGeometry height="130" width="200" x="255" y="1670" as="geometry" />
        </mxCell>
        <mxCell id="a12_note" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;fontStyle=2;fontColor=#757575;" value="(Nếu không tốt hơn:&lt;br&gt;bỏ qua, giữ đường cũ)" vertex="1">
          <mxGeometry height="40" width="150" x="500" y="1710" as="geometry" />
        </mxCell>
        <mxCell id="a13" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;strokeWidth=2;" value="⑫ CẬP NHẬT đường tốt hơn:&lt;br&gt;&lt;br&gt;1. Ghi nhận g_mới(m) = chi phí thực tế&lt;br&gt;2. Tính h(m) = khoảng cách chim bay&lt;br&gt;   từ m đến đích (Haversine × 0.6)&lt;br&gt;3. Tính f(m) = g_mới + h(m)&lt;br&gt;4. Thêm m vào Danh sách chờ xét" vertex="1">
          <mxGeometry height="120" width="340" x="185" y="1850" as="geometry" />
