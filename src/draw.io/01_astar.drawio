        <mxCell id="a8" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=12;fontStyle=1;" value="⑦ Tỉnh n có phải&lt;br&gt;là ĐIỂM ĐÍCH&lt;br&gt;không?" vertex="1">
