        <mxCell id="a5" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;fontStyle=0;" value="④ Lấy ra tỉnh có f(n) NHỎ NHẤT&lt;br&gt;trong danh sách chờ xét&lt;br&gt;&lt;br&gt;Gọi tỉnh này là &quot;n&quot;&lt;br&gt;(đây là tỉnh có vẻ hứa hẹn nhất)" vertex="1">
