        <mxCell id="phase5" value="GIAI ĐOẠN 5: HIỂN THỊ KẾT QUẢ" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontStyle=5;fontColor=#C62828;" vertex="1" parent="1">
