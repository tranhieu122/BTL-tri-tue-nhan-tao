              <mxPoint x="530" y="1400" />
              <mxPoint x="530" y="1210" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e14" value="KHÔNG (m hợp lệ, xét tiếp)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;fontColor=#2E7D32;fontStyle=1;" edge="1" parent="1" source="a10" target="a11">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="a11" target="a12">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e16" value="KHÔNG (giữ đường cũ)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;fontColor=#C62828;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="a12">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="355" y="1210" as="targetPoint" />
            <Array as="points">
              <mxPoint x="560" y="1735" />
              <mxPoint x="560" y="1210" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e17" value="CÓ (đường mới tốt hơn!)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;fontColor=#2E7D32;fontStyle=1;" edge="1" parent="1" source="a12" target="a13">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e18" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;" edge="1" parent="1" source="a13" target="a14">
