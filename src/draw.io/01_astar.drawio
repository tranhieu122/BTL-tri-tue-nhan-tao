        <mxCell id="a1" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontStyle=1;fontSize=12;" value="BẮT ĐẦU&lt;br&gt;Nhận điểm đi và điểm đến" vertex="1">
