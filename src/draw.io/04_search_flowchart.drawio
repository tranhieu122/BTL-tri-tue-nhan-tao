        </mxCell>
        <mxCell id="leg5_t" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=11;fontColor=#37474F;" value="= Thất bại / Không tìm thấy" vertex="1">
          <mxGeometry height="22" width="180" x="1020" y="451" as="geometry" />
        </mxCell>

        <!-- ========== START ========== -->
        <mxCell id="n_start" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontStyle=1;fontSize=13;shadow=1;gradientColor=#C8E6C9;gradientDirection=south;" value="BẮT ĐẦU" vertex="1">
          <mxGeometry height="60" width="230" x="340" y="100" as="geometry" />
        </mxCell>

        <!-- ========== STEP 1 ========== -->
        <mxCell id="n1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;arcSize=12;shadow=1;" value="① Tạo &lt;b&gt;Open List&lt;/b&gt; (Danh sách chờ xét)&lt;br&gt;&lt;br&gt;Ban đầu chỉ chứa điểm xuất phát,&lt;br&gt;với chi phí g = 0 và f = h(Start)&lt;br&gt;&lt;br&gt;&lt;i&gt;(Dùng Min-Heap = luôn lấy ra&lt;br&gt;phần tử có f nhỏ nhất)&lt;/i&gt;" vertex="1">
          <mxGeometry height="120" width="300" x="305" y="200" as="geometry" />
        </mxCell>

        <!-- ========== STEP 2 ========== -->
        <mxCell id="n2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;arcSize=12;shadow=1;" value="② Tạo &lt;b&gt;Closed List&lt;/b&gt; (Danh sách đã duyệt)&lt;br&gt;&lt;br&gt;Ban đầu rỗng.&lt;br&gt;Tỉnh nào đã xét xong sẽ được&lt;br&gt;cho vào đây để không xét lại." vertex="1">
          <mxGeometry height="100" width="300" x="305" y="360" as="geometry" />
        </mxCell>

        <!-- ========== STEP 3: Check open ========== -->
        <mxCell id="n3" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;fontSize=12;fontStyle=1;shadow=1;" value="③ Open List&lt;br&gt;CÒN tỉnh nào&lt;br&gt;không?" vertex="1">
          <mxGeometry height="110" width="200" x="355" y="520" as="geometry" />
        </mxCell>

        <!-- FAIL node -->
        <mxCell id="n_fail" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontStyle=1;fontSize=11;shadow=1;gradientColor=#FFEBEE;gradientDirection=south;" value="❌ KHÔNG TÌM THẤY ĐƯỜNG!&lt;br&gt;&lt;i style=&quot;font-weight:normal;&quot;&gt;(Có thể do bị chặn hết)&lt;/i&gt;" vertex="1">
          <mxGeometry height="65" width="250" x="820" y="543" as="geometry" />
        </mxCell>

        <!-- ========== STEP 4: Pop ========== -->
        <mxCell id="n4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;arcSize=12;shadow=1;strokeWidth=2;" value="④ &lt;b&gt;Lấy ra tỉnh có f(n) NHỎ NHẤT&lt;/b&gt;&lt;br&gt;trong Open List&lt;br&gt;&lt;br&gt;Gọi tỉnh này là &quot;n&quot;&lt;br&gt;&lt;i&gt;(đây là tỉnh có vẻ hứa hẹn nhất)&lt;/i&gt;" vertex="1">
          <mxGeometry height="100" width="290" x="310" y="690" as="geometry" />
        </mxCell>

        <!-- ========== STEP 5: Visited? ========== -->
        <mxCell id="n5" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;fontSize=12;shadow=1;" value="⑤ Tỉnh n này&lt;br&gt;đã duyệt rồi&lt;br&gt;chưa?" vertex="1">
          <mxGeometry height="100" width="180" x="365" y="850" as="geometry" />
        </mxCell>

        <!-- ========== STEP 6: Mark ========== -->
        <mxCell id="n6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;arcSize=12;shadow=1;" value="⑥ &lt;b&gt;Đánh dấu tỉnh n là &quot;ĐÃ DUYỆT&quot;&lt;/b&gt;&lt;br&gt;&lt;br&gt;Ghi nhận bước này vào danh sách&lt;br&gt;các bước (để sau phát hoạt ảnh)" vertex="1">
          <mxGeometry height="85" width="290" x="310" y="1010" as="geometry" />
        </mxCell>

        <!-- ========== STEP 7: Goal? ========== -->
        <mxCell id="n7" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;fontSize=12;fontStyle=1;shadow=1;" value="⑦ Tỉnh n có phải&lt;br&gt;là ĐIỂM ĐÍCH&lt;br&gt;không?" vertex="1">
          <mxGeometry height="100" width="190" x="360" y="1150" as="geometry" />
        </mxCell>

        <!-- SUCCESS -->
        <mxCell id="n_success" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontStyle=1;fontSize=11;shadow=1;gradientColor=#C8E6C9;gradientDirection=south;" value="✅ ĐÃ TÌM THẤY!&lt;br&gt;&lt;br&gt;Trả về đường đi tối ưu,&lt;br&gt;tổng chi phí (km) và các bước duyệt" vertex="1">
          <mxGeometry height="100" width="280" x="810" y="1150" as="geometry" />
        </mxCell>

        <!-- ========== STEP 8: Expand ========== -->
        <mxCell id="n8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=11;arcSize=12;shadow=1;" value="⑧ &lt;b&gt;Lấy danh sách các tỉnh KỀ&lt;/b&gt;&lt;br&gt;(các tỉnh có đường nối trực tiếp với n)&lt;br&gt;&lt;br&gt;Gọi mỗi tỉnh kề là &quot;m&quot;" vertex="1">
          <mxGeometry height="85" width="290" x="310" y="1320" as="geometry" />
        </mxCell>

        <!-- ========== STEP 9: Filter ========== -->
        <mxCell id="n9" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;fontSize=11;shadow=1;" value="⑨ Với mỗi tỉnh kề m:&lt;br&gt;m đã duyệt rồi&lt;br&gt;HOẶC đường n→m&lt;br&gt;bị chặn?" vertex="1">
          <mxGeometry height="110" width="200" x="355" y="1470" as="geometry" />
        </mxCell>

        <!-- ========== STEP 10: Calc g ========== -->
        <mxCell id="n10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=11;arcSize=12;shadow=1;" value="⑩ &lt;b&gt;Tính chi phí mới để đến m qua n:&lt;/b&gt;&lt;br&gt;&lt;br&gt;g_mới(m) = g(n) + khoảng_cách(n → m)&lt;br&gt;&lt;br&gt;&lt;i&gt;Ví dụ: nếu đã đi 200km đến n,&lt;br&gt;và n cách m là 50km → g_mới = 250km&lt;/i&gt;" vertex="1">
          <mxGeometry height="115" width="340" x="285" y="1650" as="geometry" />
        </mxCell>

        <!-- ========== STEP 11: Better? ========== -->
        <mxCell id="n11" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;fontSize=11;shadow=1;" value="⑪ Đường mới này&lt;br&gt;có TỐT HƠN đường&lt;br&gt;cũ đến m không?" vertex="1">
          <mxGeometry height="120" width="200" x="355" y="1830" as="geometry" />
        </mxCell>

        <!-- ========== STEP 12: Update ========== -->
        <mxCell id="n12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;arcSize=12;shadow=1;strokeWidth=2;" value="⑫ &lt;b&gt;CẬP NHẬT đường tốt hơn:&lt;/b&gt;&lt;br&gt;&lt;br&gt;1. Ghi nhận g_mới(m) = chi phí thực tế&lt;br&gt;2. Tính h(m) = khoảng cách chim bay&lt;br&gt;   từ m đến đích (Haversine × 0.6)&lt;br&gt;3. Tính f(m) = g_mới + h(m)&lt;br&gt;4. Thêm m vào Open List" vertex="1">
          <mxGeometry height="125" width="340" x="285" y="2020" as="geometry" />
        </mxCell>

        <!-- ========== LOOP BACK ========== -->
        <mxCell id="n_loop" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#283593;fontSize=11;fontStyle=1;dashed=1;arcSize=15;shadow=1;" value="⬆ Quay lại bước ③&lt;br&gt;(Tiếp tục lấy tỉnh có f nhỏ nhất&lt;br&gt;trong Open List)" vertex="1">
          <mxGeometry height="60" width="270" x="320" y="2200" as="geometry" />
        </mxCell>

