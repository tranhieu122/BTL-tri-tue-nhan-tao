        <mxCell id="a2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;" value="① Tạo &quot;Danh sách chờ xét&quot; (Open List)&lt;br&gt;&lt;br&gt;Ban đầu chỉ chứa điểm xuất phát,&lt;br&gt;với chi phí g = 0 và f = h(Start)&lt;br&gt;&lt;br&gt;(Danh sách này dùng Min-Heap&lt;br&gt;= luôn lấy ra phần tử có f nhỏ nhất)" vertex="1">
          <mxGeometry height="110" width="300" x="205" y="200" as="geometry" />
        </mxCell>
        <mxCell id="a3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;" value="② Tạo &quot;Danh sách đã duyệt&quot; (Visited)&lt;br&gt;&lt;br&gt;Ban đầu rỗng.&lt;br&gt;Tỉnh nào đã xét xong sẽ được&lt;br&gt;cho vào đây để không xét lại." vertex="1">
          <mxGeometry height="90" width="300" x="205" y="350" as="geometry" />
