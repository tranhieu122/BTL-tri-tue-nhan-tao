          <mxGeometry height="40" width="140" x="485" y="805" as="geometry" />
        </mxCell>
        <mxCell id="phase3" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;fontStyle=5;fontColor=#C62828;" value="XÉT TỈNH HIỆN TẠI" vertex="1">
          <mxGeometry height="25" width="150" x="40" y="910" as="geometry" />
        </mxCell>
        <mxCell id="a7" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;" value="⑥ Đánh dấu tỉnh n là &quot;ĐÃ DUYỆT&quot;&lt;br&gt;&lt;br&gt;Ghi nhận bước này vào danh sách&lt;br&gt;các bước (để sau phát hoạt ảnh)" vertex="1">
          <mxGeometry height="75" width="290" x="210" y="940" as="geometry" />
