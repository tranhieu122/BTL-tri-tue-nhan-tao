  <diagram id="astar_flow" name="Sơ đồ rút gọn A*">
    <mxGraphModel dx="1200" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ==================== TITLE ==================== -->
        <mxCell id="title" value="SƠ ĐỒ THUẬT TOÁN A* SEARCH (RÚT GỌN)" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=18;fontStyle=1;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="230" y="10" width="400" height="40" as="geometry" />
        </mxCell>

        <!-- ==================== GIẢI THÍCH CÔNG THỨC ==================== -->
        <mxCell id="formula_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;dashed=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="610" y="80" width="260" height="180" as="geometry" />
        </mxCell>
        <mxCell id="formula_title" value="💡 CÔNG THỨC CỐT LÕI" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;fontStyle=1;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="655" y="85" width="170" height="30" as="geometry" />
        </mxCell>
        <mxCell id="formula_main" value="f(n) = g(n) + h(n)" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;fontStyle=1;fontColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="655" y="115" width="170" height="30" as="geometry" />
        </mxCell>
        <mxCell id="formula_explain" value="&lt;b&gt;g(n)&lt;/b&gt;: Quãng đường thực tế đã đi (km).&lt;br&gt;&lt;b&gt;h(n)&lt;/b&gt;: Đường chim bay ước lượng đến đích.&lt;br&gt;&lt;b&gt;f(n)&lt;/b&gt;: Tổng chi phí ước tính.&lt;br&gt;&lt;i&gt;(Điểm nào có f nhỏ nhất sẽ được xét trước)&lt;/i&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;fontColor=#37474F;" vertex="1" parent="1">
          <mxGeometry x="620" y="150" width="240" height="100" as="geometry" />
        </mxCell>

        <!-- ==================== BƯỚC 1: KHỞI ĐẦU ==================== -->
        <mxCell id="a1" value="BẮT ĐẦU" style="ellipse;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="80" width="140" height="50" as="geometry" />
        </mxCell>

        <mxCell id="a2" value="Thêm điểm xuất phát vào&lt;br&gt;Danh sách chờ xét (Open List)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="160" width="220" height="50" as="geometry" />
        </mxCell>

        <!-- ==================== VÒNG LẶP CHÍNH ==================== -->
        <mxCell id="a3" value="Danh sách chờ xét&lt;br&gt;rỗng?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="250" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="a4_fail" value="Không tìm thấy đường đi" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="265" width="180" height="50" as="geometry" />
        </mxCell>

        <mxCell id="a5" value="Lấy điểm n có f(n) nhỏ nhất&lt;br&gt;trong Danh sách chờ xét ra xét" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="370" width="220" height="50" as="geometry" />
        </mxCell>

        <mxCell id="a6" value="n là Điểm đích?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="310" y="460" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="a7_success" value="Thành công! Trả về đường đi&lt;br&gt;và kết thúc" style="ellipse;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="475" width="200" height="50" as="geometry" />
        </mxCell>

        <mxCell id="a8" value="Đưa n vào Danh sách đã duyệt&lt;br&gt;(để không xét lại)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="580" width="220" height="45" as="geometry" />
        </mxCell>

        <mxCell id="a9" value="Duyệt từng điểm kề m của n&lt;br&gt;(m chưa duyệt &amp;amp; đường không bị chặn)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="270" y="660" width="240" height="50" as="geometry" />
        </mxCell>

        <mxCell id="a10" value="Tính quãng đường thực tế mới:&lt;br&gt;g_mới(m) = g(n) + khoảng cách(n → m)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="270" y="740" width="240" height="50" as="geometry" />
        </mxCell>

        <mxCell id="a11" value="Đường mới ngắn hơn&lt;br&gt;đường cũ đến m?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="300" y="820" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="a12" value="Cập nhật chi phí f(m) = g_mới + h(m)&lt;br&gt;và thêm m vào Danh sách chờ xét" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="270" y="940" width="240" height="50" as="geometry" />
        </mxCell>

        <mxCell id="a13" value="Quay lại xét điểm tiếp theo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#283593;fontSize=11;fontStyle=1;dashed=1;" vertex="1" parent="1">
