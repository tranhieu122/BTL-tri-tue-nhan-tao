        <!-- ==================== PHASE 4: XỬ LÝ ==================== -->
        <mxCell id="phase4" value="GIAI ĐOẠN 4: HỆ THỐNG XỬ LÝ TÌM ĐƯỜNG" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontStyle=5;fontColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="30" y="790" width="360" height="30" as="geometry" />
        </mxCell>

        <mxCell id="s14" value="⑬ Frontend gửi yêu cầu tìm đường&lt;br&gt;POST /api/pathfind&lt;br&gt;(gửi kèm: tỉnh đi, tỉnh đến,&lt;br&gt;thuật toán, danh sách đường bị chặn)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="830" width="280" height="75" as="geometry" />
        </mxCell>

        <mxCell id="s15" value="⑭ Backend nhận yêu cầu&lt;br&gt;Kiểm tra dữ liệu hợp lệ&lt;br&gt;(tỉnh có tồn tại không?)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="830" width="230" height="65" as="geometry" />
        </mxCell>

        <mxCell id="s16" value="⑮ Cập nhật danh sách&lt;br&gt;đường bị chặn vào&lt;br&gt;đồ thị trong bộ nhớ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="930" width="230" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s17" value="⑯ CHẠY THUẬT TOÁN TÌM KIẾM&lt;br&gt;&lt;br&gt;Ví dụ A*: tìm đường ngắn nhất&lt;br&gt;bằng công thức f(n) = g(n) + h(n)&lt;br&gt;&lt;br&gt;Ghi lại TỪNG BƯỚC máy &quot;suy nghĩ&quot;&lt;br&gt;(node nào đang xét, đường nào đang thử)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#283593;fontSize=11;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="940" width="300" height="120" as="geometry" />
        </mxCell>

        <mxCell id="s18" value="⑰ Chạy thuật toán 10 lần&lt;br&gt;rồi tính thời gian trung bình&lt;br&gt;(vì mỗi lần chạy quá nhanh)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="1100" width="250" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s19" value="⑱ Lưu kết quả vào&lt;br&gt;bảng search_history&lt;br&gt;trong Database" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="400" y="1090" width="190" height="70" as="geometry" />
        </mxCell>

        <mxCell id="es14" value="Gửi qua HTTP" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;" edge="1" parent="1" source="s13" target="s14">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="es15" value="Nhận và kiểm tra" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=10;" edge="1" parent="1" source="s14" target="s15">
