        <!-- ==================== PHASE 1: KHỞI ĐỘNG ==================== -->
        <mxCell id="phase1" value="GIAI ĐOẠN 1: KHỞI ĐỘNG HỆ THỐNG" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;fontStyle=5;fontColor=#C62828;" vertex="1" parent="1">
