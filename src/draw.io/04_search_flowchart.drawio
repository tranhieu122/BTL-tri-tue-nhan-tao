          <mxGeometry height="160" width="330" x="960" y="310" as="geometry" />
        </mxCell>
        <mxCell id="legend_title" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=13;fontStyle=1;fontColor=#37474F;" value="📌 CHÚ THÍCH HÌNH" vertex="1">
