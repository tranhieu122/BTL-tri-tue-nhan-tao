        <mxCell id="a9" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#6A1B9A;fontSize=11;" value="⑧ Lấy danh sách các tỉnh KỀ&lt;br&gt;(các tỉnh có đường nối trực tiếp với n)&lt;br&gt;&lt;br&gt;Gọi mỗi tỉnh kề là &quot;m&quot;" vertex="1">
