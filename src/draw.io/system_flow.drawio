        <mxCell id="s7" value="⑥ Server trả về danh sách&lt;br&gt;34 tỉnh thành (tọa độ GPS)&lt;br&gt;và các tuyến đường kết nối" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1">
