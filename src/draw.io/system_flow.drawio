        <mxCell id="s6" value="⑤ Trình duyệt tự động gọi&lt;br&gt;GET /api/graph&lt;br&gt;để lấy dữ liệu bản đồ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;" vertex="1" parent="1">
